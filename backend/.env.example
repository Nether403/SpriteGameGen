# The backend loads backend/.env regardless of process CWD. To select another
# dotenv file, set SPRITE_ENV_FILE in the process environment to an absolute path.

# Optional Vertex AI / Google Agent Platform auth (service-account JSON, not an
# API key). Relative paths resolve from the selected dotenv file's directory.
GOOGLE_APPLICATION_CREDENTIALS=../path/to/service-account.json

# GCP project + region for Vertex AI. Storage and Azure-only operation do not
# require these values.
# Gemini 3.x image models are served from the `global` endpoint.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=global

# Model IDs (config-only; read solely by gemini_client.py).
GEMINI_MODEL_GENERATE=gemini-3.1-flash-image
GEMINI_MODEL_EDIT=gemini-3.1-flash-image
GEMINI_MODEL_TEXT=gemini-3.5-flash
GEMINI_TIMEOUT_SECONDS=120
GEMINI_MAX_RETRIES=5
GEMINI_BACKOFF_SECONDS=1
GEMINI_QUOTA_BACKOFF_SECONDS=15

# Optional Azure OpenAI GPT Image provider. Set all three identity values or
# leave all three empty. The endpoint may be the resource URL, /openai/v1 URL,
# or the full images/generations URL; the adapter normalizes it.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_IMAGE_QUALITY=low
AZURE_IMAGE_TIMEOUT_SECONDS=180
AZURE_IMAGE_MAX_RETRIES=2
AZURE_IMAGE_MAX_CONCURRENCY=3

# Where project folders are written. Relative paths resolve from the selected
# dotenv file's directory.
PROJECTS_DIR=./projects

# Optional immediate directory of data-only JSON action packs.
ACTION_PACKS_DIR=./action-packs

# Optional independently operated local ComfyUI server. The URL must be an
# explicit loopback host and port. The descriptor and API workflow are trusted,
# operator-owned local files; SpriteGameGen never installs nodes or models.
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_DESCRIPTOR=./comfyui/workflow.sprite.json
COMFYUI_TIMEOUT_SECONDS=180
COMFYUI_POLL_INTERVAL_SECONDS=0.25

# Maximum accepted upload size in bytes.
MAX_UPLOAD_BYTES=10485760

# Whole-operation MCP deadline and process-wide creative workflow concurrency.
# Provider-specific limits still apply inside each operation.
CREATIVE_OPERATION_TIMEOUT_SECONDS=900
CREATIVE_OPERATION_MAX_CONCURRENCY=2
