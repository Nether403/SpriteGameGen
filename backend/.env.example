# Vertex AI / Google Agent Platform auth (service-account JSON, not an API key).
# Path to the service-account key file (relative to backend/ or absolute).
GOOGLE_APPLICATION_CREDENTIALS=../project-af3a95dd-a53b-4950-8d6-476937f893a9.json

# GCP project + region for Vertex AI.
# Gemini 3.x image models are served from the `global` endpoint.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=global

# Model IDs (config-only; read solely by gemini_client.py).
GEMINI_MODEL_GENERATE=gemini-3.1-flash-image
GEMINI_MODEL_EDIT=gemini-3.1-flash-image

# Where project folders are written.
PROJECTS_DIR=./projects
