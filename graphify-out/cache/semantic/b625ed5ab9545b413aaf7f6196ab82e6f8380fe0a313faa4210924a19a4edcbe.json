{"nodes": [{"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_design_spec", "label": "Sprite Game Asset Tool Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_two_tier_architecture", "label": "Two-Tier Local Architecture", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hard line between AI layer (non-deterministic Gemini) and pipeline layer (deterministic pure Python). Pipeline never calls Gemini; only transforms images."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_ai_layer", "label": "AI Layer Gemini", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_pipeline_layer", "label": "Pipeline Layer", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure Image\u2192Image functions testable with fixed input PNGs; no network, no I/O, no config reads."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_gemini_client_isolation", "label": "Gemini Client Isolation", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "gemini_client.py is the only module importing the Gemini SDK so swapping AI provider later touches one file."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_stage1_static_sprite", "label": "Stage 1 Static Sprite", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Foundation milestone: describe \u2192 clean sprite \u2192 export; shippable on its own."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_stage2_animation", "label": "Stage 2 Animation", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Motion is the moat; static alone is too small. Animated sprite \u2192 sheet + atlas with regenerate cleanup."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_base_anchored_editing", "label": "Base-Anchored Editing", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every frame passes the original base sprite plus a per-frame prompt; anchoring to one reference each call beats chaining frame\u2192frame which drifts."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_shared_bounding_box", "label": "Shared Bounding Box Alignment", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One bounding box covering every frame so the character does not jitter or resize between frames; deterministic and testable."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_regenerate_per_frame", "label": "Regenerate-Per-Frame Escape Hatch", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FrameStrip lets users delete and regenerate a single bad frame; pragmatic answer to Gemini not being frame-perfect."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_preset_actions", "label": "Preset Action Library", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reliable core idle/walk/run; best-effort attack/jump. Adding a preset = adding table rows, no new code."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_filesystem_storage", "label": "Filesystem Project Storage", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Plain filesystem, no database; each project is ./projects/<uuid>/ with project.json manifest."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_testing_strategy", "label": "Deterministic vs Non-Deterministic Testing Split", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Everything deterministic tested exhaustively and for free; the single non-deterministic seam is mocked in CI and smoke-tested by hand."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_model_selection", "label": "Configurable Gemini Model Selection", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "GEMINI_MODEL_EDIT must stay on full Flash Image because Lite is not optimized for multiple reference inputs; Stage 1 can optionally use Lite as a cost lever."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_tech_stack_tradeoff", "label": "Python Imaging Stack Tradeoff", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two-language split means two dev servers vs all-JS Next.js, but Python Pillow/NumPy/rembg imaging ecosystem is worth it for a local personal tool."}, {"id": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_guiding_decisions", "label": "Locked Guiding Decisions", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Learning/personal tool; Gemini + local post-processing; animated sprite in 2 stages; pixel and hi-res; React+Vite and FastAPI; small preset library."}], "edges": [{"source": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_two_tier_architecture", "target": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_ai_layer", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-20-sprite-game-asset-tool-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_20_sprite_game_asset_tool_design_two_tier_ar