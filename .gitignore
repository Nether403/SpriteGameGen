# --- Service-account credentials (NEVER commit) ---
# Ignore the downloaded Google service-account key at repo root by name.
# NOT a blanket *.json — that would also ignore project.json manifests and
# frontend config files.
/project-*.json
/Azurecredentials.txt

# --- Env ---
.env
.env.*
!.env.example

# --- Generated project assets ---
backend/projects/
projects/
# Manual smoke-test outputs
scripts/smoke_out/
# Disposable live model validation matrices and review artifacts
scripts/live_validation_out/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/.vite/
*.local
# TypeScript build outputs (vite.config.ts is the source of truth)
*.tsbuildinfo
frontend/vite.config.d.ts
frontend/vite.config.js

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# Stray gcloud CLI changelog dump (not a project file)
GCloud-update-notice.txt
